# ─────────────────────────────────────────────────────────────────────────────
# MPH United – IBC Form  |  Vercel Environment Variables
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Office 365 SMTP (your M365 sending account)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@mphunited.com
SMTP_PASSWORD=your-password-here

# Email routing
EMAIL_FROM=noreply@mphunited.com
EMAIL_TO=matt@mphunited.com
